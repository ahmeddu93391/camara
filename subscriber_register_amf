const { exec } = require("child_process");
const path = require("path");

const CONFIG_DIR = "/opt/camara/config";
const IMAGE = "free5gc/ueransim:latest";
const NR_UE = "/ueransim/nr-ue";

const UE_IDS = [
  "208930000000002",
  "208930000000003",
  "208930000000004",
  "208930000000005"
];

UE_IDS.forEach((UE) => {
  const yamlFile = path.join(CONFIG_DIR, `ue-${UE}.yaml`);
  console.log(`Lancement UE ${UE} ...`);

  const cmd = `docker run --rm --net=host -v ${CONFIG_DIR}:/ueransim/config ${IMAGE} ${NR_UE} -c ${yamlFile}`;

  const proc = exec(cmd, (error, stdout, stderr) => {
    if (error) {
      console.error(`Erreur UE ${UE}: ${error.message}`);
      return;
    }
    if (stderr) {
      console.error(`stderr UE ${UE}: ${stderr}`);
    }
    console.log(`stdout UE ${UE}: ${stdout}`);
  });
});
